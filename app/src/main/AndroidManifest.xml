<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.bookbuddy">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BookBuddy">

        <!-- Splash Activity (LAUNCHER) -->
        <activity
            android:name=".activities.auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.BookBuddy.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth Activities -->
        <activity
            android:name=".activities.auth.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".activities.auth.SignupActivity"
            android:exported="false" />

        <!-- Member Activities -->
        <activity
            android:name=".activities.member.MemberMainActivity"
            android:exported="false" />

        <!-- Librarian Activities -->
        <activity
            android:name=".activities.librarian.LibrarianMainActivity"
            android:exported="false" />

        <!-- Shared Activities -->
        <activity
            android:name=".activities.shared.BookDetailActivity"
            android:exported="false" />
        <activity
            android:name=".activities.shared.MyBooksActivity"
            android:exported="false" />

    </application>

</manifest>
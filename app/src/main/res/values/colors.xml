<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ========== 🦚 PEACOCK GREEN PRIMARY COLORS ========== -->
    <color name="peacock_green">#1B8C5E</color>        <!-- Primary brand color - buttons, titles -->
    <color name="peacock_green_dark">#0A5C3B</color>   <!-- Dark variant - status bar, dark text -->
    <color name="peacock_green_light">#7FBF9F</color>  <!-- Light variant - borders, hints, dividers -->
    <color name="peacock_green_soft">#E8F3EF</color>   <!-- Soft background - card backgrounds, highlights -->

    <!-- ========== ACCENT COLORS ========== -->
    <color name="gold_accent">#FFC107</color>          <!-- Gold accent - optional highlights -->

    <!-- ========== BASIC COLORS ========== -->
    <color name="black">#FF000000</color>              <!-- Primary text -->
    <color name="white">#FFFFFFFF</color>              <!-- Background, text on colored surfaces -->
    <color name="transparent">#00000000</color>        <!-- Transparent -->

    <!-- ========== GRAY COLORS (Used everywhere) ========== -->
    <color name="light_gray">#F5F5F5</color>           <!-- Backgrounds, empty states -->
    <color name="gray">#757575</color>                 <!-- Secondary text, hints -->
    <color name="dark_gray">#212121</color>            <!-- Primary text alternative -->

    <!-- ========== STATUS COLORS ========== -->
    <color name="success">#4CAF50</color>              <!-- Available books, success messages -->
    <color name="error">#F44336</color>                <!-- Error messages, validation -->
    <color name="warning">#FFC107</color>              <!-- Warning, due soon -->
    <color name="overdue">#FF5722</color>              <!-- Overdue books -->

    <!-- =========️ STATUS BAR & NAVIGATION ========== -->
    <color name="status_bar">@color/peacock_green_dark</color>    <!-- Status bar color -->
    <color name="nav_bar">@color/peacock_green</color>            <!-- Navigation bar color -->

    <!-- ========== BOOK AVAILABILITY INDICATORS ========== -->
    <color name="available">@color/success</color>                 <!-- Green for available -->
    <color name="not_available">@color/error</color>               <!-- Red for not available -->
    <color name="borrowed">@color/warning</color>                  <!-- Yellow for borrowed -->

    <!-- =========️ CARD & SURFACE COLORS ========== -->
    <color name="card_background">@color/white</color>             <!-- Book card background -->
    <color name="card_background_dark">#2D2D2D</color>             <!-- For dark mode if used -->
    <color name="divider">#E0E0E0</color>                          <!-- Dividers between sections -->

    <!-- ========== STATUS COLORS ========== -->             <!-- Error messages, validation -->
    <color name="error_red">#FF4444</color>            <!-- 👈 ADD THIS - Bright red for errors -->

</resources>
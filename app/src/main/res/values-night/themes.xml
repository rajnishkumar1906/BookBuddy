<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for night mode -->
    <style name="Base.Theme.BookBuddy" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors - slightly lighter for dark mode -->
        <item name="colorPrimary">@color/purple_300</item>
        <item name="colorPrimaryVariant">@color/purple_500</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/teal_300</item>
        <item name="colorSecondaryVariant">@color/teal_500</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Surface colors - dark mode -->
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/white</item>

        <!-- Background colors - dark mode -->
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorOnBackground">@color/white</item>

        <!-- Status bar color for dark mode -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/dark_status_bar</item>

        <!-- Navigation bar color for dark mode -->
        <item name="android:navigationBarColor" tools:targetApi="l">@color/dark_nav_bar</item>
    </style>

    <!-- Main app theme for night mode -->
    <style name="Theme.BookBuddy" parent="Base.Theme.BookBuddy">
        <!-- Typography - same as day mode but colors will adapt -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.BookBuddy.Headline1.Night</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.BookBuddy.Headline2.Night</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.BookBuddy.Headline3.Night</item>
        <item name="textAppearanceBody1">@style/TextAppearance.BookBuddy.Body1.Night</item>
        <item name="textAppearanceBody2">@style/TextAppearance.BookBuddy.Body2.Night</item>
    </style>

    <!-- Night mode TextAppearance styles -->
    <style name="TextAppearance.BookBuddy.Headline1.Night" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/purple_300</item>
    </style>

    <style name="TextAppearance.BookBuddy.Headline2.Night" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/purple_300</item>
    </style>

    <style name="TextAppearance.BookBuddy.Headline3.Night" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/purple_300</item>
    </style>

    <style name="TextAppearance.BookBuddy.Body1.Night" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.BookBuddy.Body2.Night" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/light_gray</item>
    </style>

    <!-- Splash Screen Theme for night mode -->
    <style name="Theme.BookBuddy.Splash" parent="Theme.BookBuddy">
        <item name="android:windowBackground">@color/purple_700</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@color/dark_status_bar</item>
        <item name="android:navigationBarColor">@color/dark_nav_bar</item>
    </style>

    <!-- Button Style for night mode -->
    <style name="Widget.BookBuddy.Button" parent="Widget.Material3.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- 👇 FIXED: CardView Style for night mode -->
    <style name="Widget.BookBuddy.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
    </style>
</resources>
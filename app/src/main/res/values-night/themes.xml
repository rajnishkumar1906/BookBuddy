<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.BookBuddy" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/peacock_green_light</item>
        <item name="colorPrimaryVariant">@color/peacock_green</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/gold_accent</item>
        <item name="colorSecondaryVariant">@color/warning</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/white</item>

        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorOnBackground">@color/white</item>

        <item name="android:statusBarColor" tools:targetApi="l">@color/peacock_green_dark</item>

        <item name="android:navigationBarColor" tools:targetApi="l">@color/peacock_green</item>
    </style>

    <style name="Theme.BookBuddy" parent="Base.Theme.BookBuddy">
        <!-- Typography - same as day mode but colors will adapt -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.BookBuddy.Headline1.Night</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.BookBuddy.Headline2.Night</item>
        <item name="textAppearanceHeadline3">@style/TextAppearance.BookBuddy.Headline3.Night</item>
        <item name="textAppearanceBody1">@style/TextAppearance.BookBuddy.Body1.Night</item>
        <item name="textAppearanceBody2">@style/TextAppearance.BookBuddy.Body2.Night</item>
    </style>

    <style name="TextAppearance.BookBuddy.Headline1.Night" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/peacock_green_light</item>
    </style>

    <style name="TextAppearance.BookBuddy.Headline2.Night" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/peacock_green_light</item>
    </style>

    <style name="TextAppearance.BookBuddy.Headline3.Night" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/peacock_green_light</item>
    </style>

    <style name="TextAppearance.BookBuddy.Body1.Night" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextAppearance.BookBuddy.Body2.Night" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/light_gray</item>
    </style>

    <style name="Theme.BookBuddy.Splash" parent="Theme.BookBuddy">
        <item name="android:windowBackground">@color/peacock_green_dark</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@color/peacock_green_dark</item>
        <item name="android:navigationBarColor">@color/peacock_green</item>
    </style>

    <style name="Widget.BookBuddy.Button" parent="Widget.Material3.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
        <item name="backgroundTint">@color/peacock_green</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.BookBuddy.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/dark_card_background</item>
    </style>
</resources>